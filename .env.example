# Study Timeline - Environment Variables for Docker Deployment
# Copy this file to .env.secret and fill in the values

# === Qwen Code API (from your course VM) ===
# Deploy via Docker on your VM: https://github.com/inno-se-toolkit/qwen-code-api
LLM_API_BASE_URL=http://<your-vm-ip>:<port>
LLM_API_KEY=<from qwen-code-api .env.secret>
LLM_API_MODEL=coder-model

# === Alternative: DashScope API Key (cloud) ===
# Uncomment if not using Qwen Code API
# DASHSCOPE_API_KEY=sk-xxxxx
# DASHSCOPE_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
# DASHSCOPE_MODEL=qwen-plus

# === Alternative: OpenRouter (free tier) ===
# Uncomment if not using Qwen Code API or DashScope
# OPENROUTER_API_KEY=sk-or-xxxxx
# OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
